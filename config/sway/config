set $mod Mod4
set $lock swaylock
set $menu ~/scripts/fuzzel/run.ss
font "Terminus (TTF)" 12
exec openrc -U gui
exec mako
default_orientation auto
workspace_layout tabbed
seat seat0 hide_cursor 30000
set $w0 "0|trm0"
set $w1 "1|brsr"
set $w2 "2|trm1"
set $w3 "3|msgs"
input "2:14:ETPS/2_Elantech_Touchpad" {
    events disabled
}
input * {
  xkb_layout us,ru
  xkb_options grp:win_space_toggle
  xkb_variant colemak,
  repeat_delay 200
  repeat_rate 50
}
bindsym $mod+Print exec grim 
bindsym $mod+f fullscreen
bindsym $mod+Shift+m exec swaymsg exit
bindsym $mod+Shift+p reload
bindsym $mod+1 mode "resize"
mode "resize" {
   bindsym h resize shrink width 10px
   bindsym n resize shrink height 10px
   bindsym e resize grow height 10px
   bindsym i resize grow width 10px  
   bindsym Escape mode "default"
}
bindsym $mod+v floating toggle
floating_modifier $mod normal
bindsym $mod+Shift+button1 resize
bindsym $mod+q exec st sh -c "tmux attach || tmux new"
bindsym $mod+Shift+q exec st
bindsym $mod+c kill
bindsym $mod+l exec $lock
bindsym $mod+d exec $menu
bindsym $mod+h focus left
bindsym $mod+n focus down
bindsym $mod+e focus up
bindsym $mod+i focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+n move down
bindsym $mod+Shift+e move up
bindsym $mod+Shift+i move right
bindsym $mod+a workspace $w0
bindsym $mod+r workspace $w1
bindsym $mod+s workspace $w2
bindsym $mod+t workspace $w3
bindsym $mod+Shift+a move container to workspace $w0
bindsym $mod+Shift+r move container to workspace $w1
bindsym $mod+Shift+s move container to workspace $w2
bindsym $mod+Shift+t move container to workspace $w3

bar {
  status_command i3status
  colors {
    background #221e2b
    statusline #d4d4cc
    separator  #514e6b

    #                  border  bg      text
    inactive_workspace #221e2b #221e2b #72726e
    active_workspace   #221e2b #514e6b #eaeae2
    focused_workspace  #d4d4cc #d4d4cc #221e2b
    urgent_workspace   #a8132d #a8132d #ffe8d0
  }
}
default_border pixel 1
# class                 border  bg      text    indicator child_border
client.focused          #d4d4cc #221e2b #d4d4cc #ffe8d0   #d4d4cc
client.focused_inactive #514e6b #221e2b #d4d4cc #514e6b   #514e6b
client.unfocused        #212121 #221e2b #72726e #212121   #212121
client.urgent           #a8132d #430812 #ffe8d0 #a8132d   #a8132d
client.placeholder      #212121 #212121 #d4d4cc #212121   #212121
client.background       #221e2b
exec swaybg -c c8c8be
