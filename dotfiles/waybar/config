{
  "layer": "bottom",
  "name": "bar",
  "position": "top",
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/language",
  ],
  "modules-center": [
    "sway/window",
  ],
  "modules-right": [
    "tray",
    "network",
    "wireplumber",
    "battery",
    "clock",
  ],
  "sway/workspaces": {
    "format": "{icon} {index}", 
    "disable-click": true,
    "disable-scroll": true,
    "format-icons": {
      "urgent": " ",
      "focused": " ",
      "default": " "
    }
  },
  "sway/language": {
    "format": "󰌌 {}",
    "tooltip": "{short} {variant}",
    "tooltip": true
  },
  "sway/window": {
    "format": "{}"
  },
  "sway/mode": {
    "format": "󰩨 RS",
    "tooltip": true
  },
  "battery": {
    "format": "{icon} {capacity}",
    "format-icons": ["󰂎", "󱊡", "󱊢", "󱊣"]
  },
  "network": {
    "format-wifi": "󰖩 {signalStrength}",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰌙",
    "tooltip-format": "({essid}) {ifname}: {ipaddr}/{cidr}",
    "tooltip": true
  },
  "wireplumber": {
    "format": "{icon} {volume}",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "format-muted": "󰖁 {volume}",
    "on-click": "helvum"
  },
  "pulseaudio": {
    "format": "{icon} {volume}",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "format-muted": "󰝟 0",
    "tooltip-format": "Volume: {volume}%",
    "tooltip": true
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%Y-%m-%d %H:%M}",
    "tooltip": true
  },
  "tray": {
    "spacing": 10
  }
}