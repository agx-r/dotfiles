#!/usr/bin/env guile
!#
(define-module (launcher)
  #:use-module (ice-9 popen)
  #:use-module (ice-9 rdelim)
  #:use-module (srfi srfi-1))

(define launch-list-file "~/.config/fuzzel/launch-list")

(define (expand-home path)
  "Expand ~ in a path to the user's home directory."
  (if (string-prefix? "~" path)
      (string-append (getenv "HOME") (substring path 1))
      path))

(define (read-launch-list)
  (call-with-input-file (expand-home launch-list-file)
    (lambda (port)
      (let loop ((lines '()))
        (let ((line (read-line port)))
          (if (eof-object? line)
              (reverse lines)
              (loop (cons line lines))))))))

(define (main)
  (let* ((choices (read-launch-list))
         (choice (with-input-from-port
                  (open-input-pipe
                   (string-append "echo \"" (string-join choices "\n") "\" | fuzzel --dmenu"))
                  read-line)))
    (cond
     ((string=? choice "ŅĪĮ qutebrowser") (system "qutebrowser"))
     ((string=? choice "ŅØģ librewolf") (system "librewolf"))
     ((string=? choice "ŅØā chromium") (system "chromium"))
     ((string=? choice "¾▒ŗ┐ wireplumber") (system "wireplumber"))
     ((string=? choice "¾▒ŗ┐ wireplumber kill") (system "pkill wireplumber"))
     ((string=? choice "’Ź░ icedove") (system "icedove"))
     ((string=? choice "’Éō ranger") (system "foot -e ranger"))
     ((string=? choice "Ņ¤Å emacs client") (system "emacsclient"))
     ((string=? choice "Ņ¤Å emacs standalone") (system "emacs"))
     ((string=? choice "’ŗå telegram") (system "flatpak run org.telegram.desktop"))
     ((string=? choice "’ŗå telegram kill") (system "flatpak kill org.telegram.desktop"))
     ((string=? choice "’ŹČ libreoffice") (system "flatpak run org.libreoffice.LibreOffice"))
     ((string=? choice "¾░Ģ¦ obs studio") (system "flatpak run com.obsproject.Studio"))
     ((string=? choice "ŅĀü inkscape") (system "flatpak run org.inkscape.Inkscape"))
     ((string=? choice "’īČ freecad") (system "flatpak run org.freecad.FreeCAD"))
     ((string=? choice "ŅĪ« prismlauncher") (system "flatpak run org.prismlauncher.PrismLauncher"))
     ((string=? choice "’ŗć air conditioner ON") (system "~/.local/bin/ac-on.sh && fyi -t 2000 mqtt 'AC powered ON'"))
     ((string=? choice "’ŗŗ air conditioner OFF") (system "~/.local/bin/ac-off.sh && fyi -t 2000 mqtt 'AC powered OFF'"))
     ((string=? choice "ŅŁ£ color pick")
      (let ((color (with-input-from-port
                    (open-input-pipe
                     "grim -g \"$(slurp -b 00000000 -p)\" -t ppm - 2>/tmp/grim.err | convert - -format '%[pixel:p{0,0}]' txt:- 2>/tmp/convert.err | tail -n 1 | cut -d ' ' -f 4")
                    read-line)))
        (if color
            (begin
              (system (string-append "echo \"" color "\" | wl-copy"))
              (system (string-append "fyi -t 3000 Picked \"" color "\"")))
            (system "fyi Error 'Failed to pick color'"))))
     ((string=? choice "’ć┐ vencord") (system "flatpak run dev.vencord.Vesktop"))
     ((string=? choice "’ć┐ vencord kill") (system "flatpak kill dev.vencord.Vesktop"))
     ((string=? choice "ŅØģ zen") (system "flatpak run app.zen_browser.zen"))
     ((string=? choice "¾░£ē reboot") (system "lxqt-sudo reboot"))
     ((string=? choice "¾░Éź shutdown") (system "lxqt-sudo shutdown"))
     ((string=? choice "¾░Éź poweroff") (system "lxqt-sudo shutdown"))
     ((string=? choice "¾░āĀ brightness MAX") (system "lxqt-sudo brightnessctl set 15"))
     ((string=? choice "¾░ā¤ brightness DEF") (system "lxqt-sudo brightnessctl set 10"))
     ((string=? choice "¾░ā× brightness MIN") (system "lxqt-sudo brightnessctl set 0"))
     ((string=? choice "’ī╝ kdenlive") (system "flatpak run org.kde.kdenlive"))
     ((string=? choice "¾░łć remmina") (system "flatpak run org.remmina.Remmina"))
     ((string=? choice "¾░ōō steam") (system "flatpak run com.valvesoftware.Steam"))
     ((string=? choice "¾░ōō steam kill") (system "flatpak kill com.valvesoftware.Steam"))
     ((string=? choice "’ćł time machine") (system "record-buffer.sh save"))
     ((string=? choice "¾░æł last video") (system "mpv ~/videos/$(ls -t ~/videos | head -n 1)"))
     ((string=? choice "’ĆŠ last screenshot") (system "imv $(ls -t ~/pictures/screenshot-* | head -n 1)"))
     ((string=? choice "¾░¢® nmtui") (system "foot -e sudo nmtui"))
     ((string=? choice "¾░āÆ split vertical") (system "swaymsg layout splitv"))
     ((string=? choice "¾░āŖ split horizontal") (system "swaymsg layout splith"))
     ((string=? choice "¾░ō¬ split tabbed") (system "swaymsg layout tabbed"))
     ((string=? choice "ŅśĢ dotfiles dir") (system "foot -D ~/guix-home/dotfiles/"))
     ((string=? choice "’īź guix home") (system "foot -D ~/guix-home/"))
     ((string=? choice "Ņ«ó projects") (system "foot -D ~/projects/"))
     ((string=? choice "¾░é» bluetoothctl") (system "foot -e sudo bluetoothctl"))
     ((string=? choice "¾░æō sway reload") (system "swaymsg reload"))
     (else (exit 1)))))

(main)
