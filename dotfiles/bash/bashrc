# ===== COLOR VARIABLES =====
BOLD_MAGENTA='\e[1;35m'
MAGENTA='\e[0;35m'
BOLD_BLACK='\e[1;30m'
BLUE='\e[0;34m'
RED='\e[0;31m'
BACKGROUND_RED='\e[41m'
BACKGROUND_BLUE='\e[44m'
GREEN='\e[0;32m'
YELLOW='\e[0;33m'
BOLD_YELLOW='\e[1;33m'
BOLD_BLUE='\e[1;34m'
RESET='\e[0m'

# ===== GIT BRANCH FUNCTION =====
parse_git_branch() {
    local branch
    branch=$(git branch 2>/dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/')
    if [ -n "$branch" ]; then
        local status
        status=$(git status --porcelain 2>/dev/null)
        local color
        if [ -z "$status" ]; then
            color="${GREEN}"  # Clean repository
        else
            color="${RED}" # Dirty repository
        fi
        echo -e "${color} ’Éś ${branch}${RESET}"
    fi
}

