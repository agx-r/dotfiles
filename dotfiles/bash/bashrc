# ===== FUNCTIONS =====
_return_code() {
    local rc=$?
    if [ $rc -eq 0 ]; then
        echo -e "${BOLD_MAGENTA}Ō£ö ${BLUE}| ${RESET}"
    else
        echo -e "${RED}ŅéČ${BOLD_BLACK}${BACKGROUND_RED}Ō£ś $rc${RESET}${RED}Ņé┤ ${BLUE}| ${RESET}"
    fi
}


function mark() {
  export MARKED_DIR=$(pwd)
  echo "Marked"
}

function hook() {
  if [[ -n $MARKED_DIR ]]; then
    echo "${BOLD_MAGENTA}Hooked $MARKED_DIR"
    c "$MARKED_DIR"
  else
    echo "No marks to hook."
  fi
}
